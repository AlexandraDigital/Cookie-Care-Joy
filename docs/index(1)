<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Cookie-Care-Joy 🍪</title>
  <script src="https://median.co/app.js"></script>

  <script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer></script>
  <script>
    window.OneSignalDeferred = window.OneSignalDeferred || [];
    OneSignalDeferred.push(async function(OneSignal) {
      await OneSignal.init({
        appId: "249f07c6-54a2-4e50-a5ec-f9021b61e47c",
        serviceWorkerPath: "OneSignalSDKWorker.js",
        serviceWorkerUpdaterPath: "OneSignalSDKUpdaterWorker.js"
      });
    });
  </script>

  
   

  <style>
    
    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
    }

    body {
      background: #fdf6fb;
      font-family: system-ui, -apple-system, sans-serif;
    }

    #root {
      min-height: 100vh;
      min-height: -webkit-fill-available;
    }

    button,
    input {
      font-family: inherit;
    }

    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    ::-webkit-scrollbar-thumb {
      background: #f9a8d4;
      border-radius: 999px;
    }

    .time-col::-webkit-scrollbar {
      display: none;
    }

    .night-overlay {
      position: fixed;
      inset: 0;
      z-index: 9000;
      pointer-events: none;
      background: linear-gradient(to bottom, rgba(180, 120, 60, 0.08) 0%, rgba(140, 80, 30, 0.13) 100%);
      animation: nightFadeIn 2s ease forwards;
    }

    body.night {
      background: #f9f0e6 !important;
    }

    .night-badge {
      position: fixed;
      top: max(14px, env(safe-area-inset-top));
      right: 16px;
      z-index: 9001;
      background: rgba(254, 243, 199, 0.85);
      border: 1px solid rgba(217, 119, 6, 0.25);
      border-radius: 20px;
      padding: 5px 12px;
      font-size: 12px;
      font-weight: 600;
      color: #92400e;
      backdrop-filter: blur(8px);
      pointer-events: none;
      animation: nightFadeIn 3s ease forwards;
      letter-spacing: 0.2px;
    }

    .top-nav {
      display: flex;
    }

    .bottom-nav {
      display: none;
    }

    @keyframes breatheIn {
      0% {
        transform: scale(1);
        opacity: 0.7
      }

      100% {
        transform: scale(1.55);
        opacity: 1
      }
    }

    @keyframes breatheOut {
      0% {
        transform: scale(1.55);
        opacity: 1
      }

      100% {
        transform: scale(1);
        opacity: 0.7
      }
    }

    @keyframes breatheHold {

      0%,
      100% {
        transform: scale(1.55)
      }
    }

    @keyframes ripple1 {
      0% {
        transform: scale(1);
        opacity: 0.4
      }

      100% {
        transform: scale(2.2);
        opacity: 0
      }
    }

    @keyframes ripple2 {
      0% {
        transform: scale(1);
        opacity: 0.3
      }

      100% {
        transform: scale(2.8);
        opacity: 0
      }
    }

    @keyframes nightFadeIn {
      from {
        opacity: 0
      }

      to {
        opacity: 1
      }
    }

    @keyframes slideDown {
      0% {
        transform: translateY(-100%);
        opacity: 0
      }

      100% {
        transform: translateY(0);
        opacity: 1
      }
    }

    @keyframes btnPulse {

      0%,
      100% {
        transform: scale(1);
        box-shadow: 0 2px 12px rgba(244, 63, 110, 0.2)
      }

      50% {
        transform: scale(1.06);
        box-shadow: 0 4px 20px rgba(244, 63, 110, 0.45)
      }
    }

    @keyframes coolIn {
      0% {
        opacity: 0;
        transform: scale(1.04)
      }

      100% {
        opacity: 1;
        transform: scale(1)
      }
    }

    @keyframes coolOut {
      0% {
        opacity: 1
      }

      100% {
        opacity: 0
      }
    }

    @keyframes timerTick {
      0% {
        opacity: 1
      }

      50% {
        opacity: 0.5
      }

      100% {
        opacity: 1
      }
    }

    @keyframes cookieDrop {
      0% {
        transform: translateY(-120px) rotate(-20deg) scale(0.4);
        opacity: 0
      }

      60% {
        transform: translateY(10px) rotate(6deg) scale(1.1);
        opacity: 1
      }

      80% {
        transform: translateY(-6px) rotate(-3deg) scale(0.97)
      }

      100% {
        transform: translateY(0) rotate(0deg) scale(1);
        opacity: 1
      }
    }

    @keyframes cookiePulse {

      0%,
      100% {
        transform: scale(1) rotate(0deg)
      }

      25% {
        transform: scale(1.08) rotate(-4deg)
      }

      75% {
        transform: scale(1.05) rotate(3deg)
      }
    }

    @keyframes crumbFly1 {
      0% {
        transform: translate(0, 0) scale(1);
        opacity: 1
      }

      100% {
        transform: translate(-60px, -80px) scale(0.3) rotate(200deg);
        opacity: 0
      }
    }

    @keyframes crumbFly2 {
      0% {
        transform: translate(0, 0) scale(1);
        opacity: 1
      }

      100% {
        transform: translate(70px, -90px) scale(0.2) rotate(-160deg);
        opacity: 0
      }
    }

    @keyframes crumbFly3 {
      0% {
        transform: translate(0, 0) scale(1);
        opacity: 1
      }

      100% {
        transform: translate(-40px, 60px) scale(0.4) rotate(120deg);
        opacity: 0
      }
    }

    @keyframes crumbFly4 {
      0% {
        transform: translate(0, 0) scale(1);
        opacity: 1
      }

      100% {
        transform: translate(50px, 70px) scale(0.3) rotate(-90deg);
        opacity: 0
      }
    }

    @keyframes crumbFly5 {
      0% {
        transform: translate(0, 0) scale(1);
        opacity: 1
      }

      100% {
        transform: translate(90px, -40px) scale(0.2) rotate(240deg);
        opacity: 0
      }
    }

    @keyframes crumbFly6 {
      0% {
        transform: translate(0, 0) scale(1);
        opacity: 1
      }

      100% {
        transform: translate(-80px, 30px) scale(0.35) rotate(-180deg);
        opacity: 0
      }
    }

    @keyframes splashTextIn {
      0% {
        opacity: 0;
        transform: translateY(24px) scale(0.9)
      }

      100% {
        opacity: 1;
        transform: translateY(0) scale(1)
      }
    }

    @keyframes splashSubIn {
      0% {
        opacity: 0;
        transform: translateY(12px)
      }

      100% {
        opacity: 1;
        transform: translateY(0)
      }
    }

    @keyframes splashFadeOut {
      0% {
        opacity: 1;
        transform: scale(1)
      }

      80% {
        opacity: 1;
        transform: scale(1)
      }

      100% {
        opacity: 0;
        transform: scale(1.04)
      }
    }

    @keyframes sparkle {
      0% {
        transform: scale(0) rotate(0deg);
        opacity: 0
      }

      40% {
        transform: scale(1.3) rotate(180deg);
        opacity: 1
      }

      100% {
        transform: scale(0) rotate(360deg);
        opacity: 0
      }
    }

    .notif-mobile {
      display: none;
    }

    /* legacy */
    .desktop,.mobile,.tablet,.touchscreen {
      display: flex !important;
    }

    .float-hide-desktop,.mobile,.tablet,.touchscreen {
      display: none !important;
    }

    .desktop,.mobile,.tablet,.touchscreen-save-dropdown {
      position: fixed !important;
      top: 72px !important;
      right: 20px !important;
      bottom: auto !important;
      left: auto !important;
    }

    .nav-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 28px 0 0;
      height: 64px;
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .notif-desktop,.notif-mobile,.notif-tablet,.notif-touchscreen{
      display: block;
    }

    @media (max-width: 600px) {
      .top-nav {
        display: none !important;
      }

      .bottom-nav {
        display: flex !important;
      }

      .page-content {
        padding-bottom: 80px !important;
      }

      .cookie-earn-bar {
        padding: 8px 12px !important;
        border-radius: 12px !important;
      }

      .cookie-earn-bar span:first-child {
        font-size: 16px !important;
      }

      .cookie-earn-bar span:last-child {
        font-size: 12px !important;
      }

      .notif-mobile {
        display: flex !important;
      }

      .notif-desktop,.notif-mobile,.notif-tablet,.notif-touchscreen {
        display: none !important;
      }

      .desktop,.mobile,.tablet,.touchscreen {
        display: none !important;
      }

      .float-hide-desktop {
        display: flex !important;
      }

      .desktop,.mobile,.tablet,.touchscreen-save-dropdown {
        position: absolute !important;
        top: auto !important;
        right: auto !important;
        bottom: calc(100% + 10px) !important;
        left: 0 !important;
      }
    }
  </style>

</head>



<body>
  <div id="root"></div>
 

  <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>

  <script type="text/babel"> 
    const { useState, useEffect } = React;

    const App = () => {
      // Your app code
      return (
        <div className="p-4 text-center">
          <h1>Cookie-Care-Joy 🍪</h1>
        </div>
      );
    };

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>



  

</body>
</head>
</html>
