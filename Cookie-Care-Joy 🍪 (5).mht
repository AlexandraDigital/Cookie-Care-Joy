@charset "utf-8";

*, ::before, ::after { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

html, body { margin: 0px; padding: 0px; width: 100%; height: 100%; }

body { background: rgb(253, 246, 251); font-family: system-ui, -apple-system, sans-serif; overscroll-behavior: none; text-size-adjust: 100%; }

body, html { background: rgb(253, 246, 251); }

#root { min-height: -webkit-fill-available; }

button, input { font-family: inherit; }

::-webkit-scrollbar { width: 6px; height: 6px; }

::-webkit-scrollbar-track { background: transparent; }

::-webkit-scrollbar-thumb { background: rgb(249, 168, 212); border-radius: 999px; }

.time-col::-webkit-scrollbar { display: none; }

.night-overlay { position: fixed; inset: 0px; z-index: 9000; pointer-events: none; background: linear-gradient(rgba(180, 120, 60, 0.08) 0%, rgba(140, 80, 30, 0.13) 100%); animation: 2s ease 0s 1 normal forwards running nightFadeIn; }

body.night { background: rgb(249, 240, 230) !important; }

.night-badge { position: fixed; top: max(14px, env(safe-area-inset-top)); right: 16px; z-index: 9001; background: rgba(254, 243, 199, 0.85); border: 1px solid rgba(217, 119, 6, 0.25); border-radius: 20px; padding: 5px 12px; font-size: 12px; font-weight: 600; color: rgb(146, 64, 14); backdrop-filter: blur(8px); pointer-events: none; animation: 3s ease 0s 1 normal forwards running nightFadeIn; letter-spacing: 0.2px; }

.top-nav { display: flex; }

.bottom-nav { display: none; }

@keyframes breatheIn { 
  0% { transform: scale(1); opacity: 0.7; }
  100% { transform: scale(1.55); opacity: 1; }
}

@keyframes breatheOut { 
  0% { transform: scale(1.55); opacity: 1; }
  100% { transform: scale(1); opacity: 0.7; }
}

@keyframes breatheHold { 
  0%, 100% { transform: scale(1.55); }
}

@keyframes ripple1 { 
  0% { transform: scale(1); opacity: 0.4; }
  100% { transform: scale(2.2); opacity: 0; }
}

@keyframes ripple2 { 
  0% { transform: scale(1); opacity: 0.3; }
  100% { transform: scale(2.8); opacity: 0; }
}

@keyframes nightFadeIn { 
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes slideDown { 
  0% { transform: translateY(-100%); opacity: 0; }
  100% { transform: translateY(0px); opacity: 1; }
}

@keyframes btnPulse { 
  0%, 100% { transform: scale(1); box-shadow: rgba(244, 63, 110, 0.2) 0px 2px 12px; }
  50% { transform: scale(1.06); box-shadow: rgba(244, 63, 110, 0.45) 0px 4px 20px; }
}

@keyframes coolIn { 
  0% { opacity: 0; transform: scale(1.04); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes coolOut { 
  0% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes micPulse { 
  0%, 100% { box-shadow: rgba(255, 110, 180, 0.3) 0px 0px 0px 3px; }
  50% { box-shadow: rgba(255, 110, 180, 0.1) 0px 0px 0px 7px; }
}

@keyframes timerTick { 
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

@keyframes cookieDrop { 
  0% { transform: translateY(-120px) rotate(-20deg) scale(0.4); opacity: 0; }
  60% { transform: translateY(10px) rotate(6deg) scale(1.1); opacity: 1; }
  80% { transform: translateY(-6px) rotate(-3deg) scale(0.97); }
